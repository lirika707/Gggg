rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'admin' | 'user')
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: string (required)
    //   - quantity: string (optional)
    //   - location: string (optional)
    //   - date: string (optional)
    //   - category: string (required)
    //   - badge: string (optional)
    //   - description: string (required)
    //   - rating: number (optional)
    //   - image: string (optional)
    //   - sellerId: string (required)
    //   - sellerName: string (optional)
    //   - sellerAvatar: string (optional)
    //   - sellerRating: number (optional)
    //   - sellerPhone: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: services
    // Document ID: {serviceId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: string (required)
    //   - location: string (optional)
    //   - category: string (required)
    //   - description: string (required)
    //   - rating: number (optional)
    //   - image: string (optional)
    //   - providerId: string (required)
    //   - providerName: string (optional)
    //   - providerAvatar: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nterra558@gmail.com" && request.auth.token.email_verified == true) ||
          request.auth.token.email == "admin@admin.app");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'createdAt']) &&
             data.uid is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'description', 'sellerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is string &&
             data.category is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.sellerId is string &&
             data.createdAt is timestamp;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'description', 'providerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is string &&
             data.category is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.providerId is string &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'category', 'createdAt']) &&
             data.userId is string &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string &&
             data.createdAt is timestamp;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'content', 'createdAt']) &&
             data.userId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.createdAt is timestamp;
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['followerId', 'followingId', 'createdAt']) &&
             data.followerId is string &&
             data.followingId is string &&
             data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'senderId', 'read', 'createdAt']) &&
             data.userId is string &&
             data.type in ['like', 'follow'] &&
             data.senderId is string &&
             data.read is bool &&
             data.createdAt is timestamp;
    }

    function isValidAIChatMessage(data) {
      return data.keys().hasAll(['userId', 'text', 'sender', 'createdAt']) &&
             data.userId is string &&
             data.text is string &&
             data.sender in ['user', 'ai'] &&
             data.createdAt is timestamp;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['productId', 'createdAt']) &&
             data.productId is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId}/favorites/{productId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidFavorite(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId}/ai_messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidAIChatMessage(request.resource.data) && request.resource.data.userId == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidAIChatMessage(request.resource.data) && request.resource.data.userId == userId;
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId} {
      allow read: if true; // Public read for profile info
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidFollow(request.resource.data) && (request.resource.data.followerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.followerId == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data) && (request.resource.data.senderId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProduct(request.resource.data) && (request.resource.data.sellerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidProduct(request.resource.data) && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidService(request.resource.data) && (request.resource.data.providerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidService(request.resource.data) && (resource.data.providerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidTransaction(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
