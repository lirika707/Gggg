{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product listed in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "quantity": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "badge": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerAvatar": { "type": "string" },
        "sellerRating": { "type": "number" },
        "sellerPhone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "description", "sellerId"]
    },
    "Service": {
      "title": "Service",
      "description": "A service listed in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "providerId": { "type": "string" },
        "providerName": { "type": "string" },
        "providerAvatar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "description", "providerId"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "login": { "type": "string" },
        "normalizedLogin": { "type": "string" },
        "authEmail": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "fullName": { "type": "string" },
        "displayName": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "postsCount": { "type": "number" },
        "listingsCount": { "type": "number" },
        "soldCount": { "type": "number" },
        "rating": { "type": "number" },
        "verified": { "type": "boolean" },
        "quickRegistration": { "type": "boolean" },
        "registrationLevel": { "type": "string" },
        "provider": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "A blog post created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "category"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "follow"] },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "postId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "senderId", "read", "createdAt"]
    },
    "AIChatMessage": {
      "title": "AIChatMessage",
      "description": "A message in an AI assistant conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "timestamp": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "sender", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/ai_messages/{messageId}": {
      "schema": "AIChatMessage",
      "description": "Collection of AI messages for a user"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of transactions"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Collection of follow relationships"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of notifications"
    }
  }
}
